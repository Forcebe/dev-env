#!/usr/bin/env bash
# Tmux session layout for nucleus, called by tmux-sessionizer.
# Deployed by dev-env and excluded from git via .git/info/exclude.
# Source: https://github.com/Forcebe/dev-env

session=$1
dir=$2

tmux rename-window -t "=$session:0" "nucleus-dev"
pane=$(tmux list-panes -t "=$session:0" -F '#{pane_id}' | head -1)
tmux send-keys -t "$pane" "nvim ." Enter
new_pane=$(tmux split-window -v -t "$pane" -c "$dir" -PF '#{pane_id}')
bottom_right=$(tmux split-window -h -t "$new_pane" -c "$dir" -PF '#{pane_id}')
tmux send-keys -t "$bottom_right" "claude" Enter
tmux select-pane -t "$pane"

tmux new-window -t "=$session" -n "nucleus-run" -c "$dir"
run_pane=$(tmux list-panes -t "=$session:nucleus-run" -F '#{pane_id}' | head -1)
tmux send-keys -t "$run_pane" "npm install && npm run storybook" Enter
tmux select-window -t "=$session:nucleus-dev"
