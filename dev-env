#!/usr/bin/env bash

script_dir="$(cd $(dirname "${BASH_SOURCE[0]}") && pwd)"

# --- Layer resolution ---
# When called via `run`, CURRENT_LAYER is already exported.
# When called standalone, resolve from flags or layer file.
if [[ -z "$CURRENT_LAYER" ]]; then
    layer_flag=""
    while [[ $# > 0 ]]; do
        case "$1" in
            --dry) export DRY="1" ;;
            --work) layer_flag="work" ;;
            --personal) layer_flag="personal" ;;
        esac
        shift
    done

    LAYER_FILE="$HOME/.dev-env-layer"
    if [[ "${DRY:-0}" == "0" ]]; then
        if [[ "$layer_flag" == "work" ]]; then
            echo "work" > "$LAYER_FILE"
        elif [[ "$layer_flag" == "personal" ]]; then
            rm -f "$LAYER_FILE"
        fi
    fi

    # Resolve layer: flag overrides file
    if [[ "$layer_flag" == "work" ]]; then
        export CURRENT_LAYER="work"
    elif [[ "$layer_flag" == "personal" ]]; then
        export CURRENT_LAYER="personal"
    elif [[ -f "$LAYER_FILE" ]]; then
        export CURRENT_LAYER
        CURRENT_LAYER=$(cat "$LAYER_FILE")
        if [[ "$CURRENT_LAYER" != "work" && "$CURRENT_LAYER" != "personal" ]]; then
            echo "WARNING: unknown layer '$CURRENT_LAYER' in $LAYER_FILE, defaulting to personal" >&2
            export CURRENT_LAYER="personal"
        fi
    else
        export CURRENT_LAYER="personal"
    fi
else
    # Called via run — still parse --dry for standalone compat
    while [[ $# > 0 ]]; do
        case "$1" in
            --dry) export DRY="1" ;;
        esac
        shift
    done
fi

source "$script_dir/runs/_lib.sh"

WORK_OP_ACCOUNT="tmrw-health.1password.com"

# Resolve the 1Password account for the current layer.
# Work: hardcoded to the TMRW account.
# Personal: the first signed-in account in `op account list` that isn't work.
# `op account list` column order assumption: URL is column 1 (stable across 2.x).
resolve_op_account() {
	if [[ "$CURRENT_LAYER" == "work" ]]; then
		echo "$WORK_OP_ACCOUNT"
	else
		op account list 2>/dev/null \
			| awk -v work="$WORK_OP_ACCOUNT" 'NR>1 && $1 != work { print $1; exit }'
	fi
}

copy_dir() {
	local from=$1
	local to=$2

	pushd $from > /dev/null
	dirs=$(find . -maxdepth 1 -mindepth 1 -type d)
	for dir in $dirs; do
		execute rm -rf $to/$dir
		execute cp -rp $dir $to/$dir
	done
	files=$(find . -maxdepth 1 -mindepth 1 -type f)
	for file in $files; do
		execute cp -p $file $to/$file
	done
	popd > /dev/null
}

copy_file() {
	local from="$1"
	local to="$2"
	local name
	name="$(basename "$from")"

	execute rm -f "$to/$name"
	execute cp "$from" "$to/$name"
}

# --- Personal config (always applied) ---

log_section "Config dirs"
log_step "Copying .config, .local, .claude"
copy_dir home/.config $HOME/.config
copy_dir home/.local $HOME/.local
copy_dir home/.claude $HOME/.claude

log_section "Config files"
log_step "Copying .zshrc, .gitconfig"
copy_file home/.zshrc $HOME
copy_file home/.gitconfig $HOME

log_section "Cursor settings"
log_step "Copying cursor settings"
execute mkdir -p "$HOME/Library/Application Support/Cursor/User"
copy_file home/.config/cursor/settings.json "$HOME/Library/Application Support/Cursor/User"

log_section "ready-tmux scripts"
log_step "Copying .ready-tmux"
copy_file home/.ready-tmux $HOME

# --- Secrets injection (both layers; templates live in home/.zshrc) ---

# `op account list` returns 0 with empty output when no account is added,
# so a non-empty line count is the real signal of an authenticated CLI.
op_authenticated() {
	command -v op &>/dev/null || return 1
	local lines
	lines=$(op account list 2>/dev/null | wc -l)
	[[ "$lines" -ge 2 ]]
}

log_section "1Password secrets injection"
if ! command -v op &>/dev/null; then
	log_skip "op CLI not installed, skipping secrets injection"
	log_manual "Install 1Password CLI + sign in, then re-run './dev-env' to populate secrets in ~/.zshrc"
elif ! op_authenticated; then
	log_skip "op CLI not authenticated, skipping secrets injection"
	log_manual "Sign in to 1Password CLI, then re-run './dev-env' to populate secrets in ~/.zshrc"
else
	op_account=$(resolve_op_account)
	if [[ -z "$op_account" ]]; then
		log_skip "Could not resolve 1Password account for layer=$CURRENT_LAYER, skipping"
		log_manual "Sign in to the ${CURRENT_LAYER} 1Password account, then re-run './dev-env'"
	else
		log_step "Injecting secrets into .zshrc (account=$op_account)"
		if execute op inject -i "$HOME/.zshrc" -o "$HOME/.zshrc.tmp" --account "$op_account"; then
			execute mv "$HOME/.zshrc.tmp" "$HOME/.zshrc"
		else
			log_skip "op inject failed, leaving .zshrc untouched"
			execute rm -f "$HOME/.zshrc.tmp"
			log_manual "Re-run './dev-env' after resolving 1Password issue"
		fi
	fi
fi

# --- Work overlay (only when layer=work) ---

if [[ "$CURRENT_LAYER" == "work" ]]; then
	log_section "Work config overlays"
	log_step "Copying work .gitconfig"
	copy_file home-work/.gitconfig $HOME
	log_step "Copying work .claude/settings.json"
	copy_file home-work/.claude/settings.json $HOME/.claude
	log_step "Copying work .local/scripts/tmux-sessionizer"
	copy_file home-work/.local/scripts/tmux-sessionizer $HOME/.local/scripts

	log_section "TMRW ready-tmux scripts"
	execute mkdir -p "$HOME/tmrw"
	log_step "cp tmrw/tmrw.ready-tmux -> ~/tmrw/.ready-tmux"
	if [[ "$DRY" == "0" ]]; then
		cp "$script_dir/tmrw/tmrw.ready-tmux" "$HOME/tmrw/.ready-tmux"
	fi
	for repo in tmrw-client tmrw-protocols tmrw-core-api; do
		repo_dir="$HOME/tmrw/$repo"
		log_step "cp tmrw/$repo.ready-tmux -> ~/tmrw/$repo/.ready-tmux"
		if [[ "$DRY" == "0" ]]; then
			cp "$script_dir/tmrw/$repo.ready-tmux" "$repo_dir/.ready-tmux"
		fi
		exclude="$repo_dir/.git/info/exclude"
		if [[ -f "$exclude" ]] && ! grep -q '\.ready-tmux' "$exclude"; then
			echo ".ready-tmux" >> "$exclude"
		fi
	done
fi
