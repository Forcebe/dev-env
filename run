#!/usr/bin/env bash

script_dir=$(cd $(dirname "${BASH_SOURCE[0]}") && pwd)
filter=""
export DRY="0"
layer_flag=""

# --- Arg parsing ---
while [[ $# > 0 ]]; do
	case "$1" in
		--dry) DRY="1" ;;
		--work) layer_flag="work" ;;
		--personal) layer_flag="personal" ;;
		*) filter="$1" ;;
	esac
	shift
done

# --- Layer resolution ---
LAYER_FILE="$HOME/.dev-env-layer"

if [[ "$DRY" == "0" ]]; then
	if [[ "$layer_flag" == "work" ]]; then
		echo "work" > "$LAYER_FILE"
	elif [[ "$layer_flag" == "personal" ]]; then
		rm -f "$LAYER_FILE"
	fi
fi

# Resolve layer: flag overrides file
if [[ "$layer_flag" == "work" ]]; then
	export CURRENT_LAYER="work"
elif [[ "$layer_flag" == "personal" ]]; then
	export CURRENT_LAYER="personal"
elif [[ -f "$LAYER_FILE" ]]; then
	export CURRENT_LAYER
	CURRENT_LAYER=$(cat "$LAYER_FILE")
	# Normalize unknown values to personal
	if [[ "$CURRENT_LAYER" != "work" && "$CURRENT_LAYER" != "personal" ]]; then
		echo "WARNING: unknown layer '$CURRENT_LAYER' in $LAYER_FILE, defaulting to personal" >&2
		export CURRENT_LAYER="personal"
	fi
else
	export CURRENT_LAYER="personal"
fi

# Manual steps collection
export MANUAL_STEPS_FILE
MANUAL_STEPS_FILE=$(mktemp)
trap 'rm -f "$MANUAL_STEPS_FILE"' EXIT

# --- Dependency resolution ---
# Store scripts and deps as parallel arrays (bash 3.2 compatible)
# script_names[i] corresponds to script_dep_list[i] and script_dirs[i]

script_names=()
script_dep_list=()
script_dirs=()

cd "$script_dir"

# Scan personal scripts from runs/
for script_path in runs/*; do
	[[ -f "$script_path" ]] || continue
	name=$(basename "$script_path")
	# Skip _-prefixed files (_lib.sh etc)
	case "$name" in _*) continue ;; esac

	script_names+=("$name")
	script_dirs+=("runs")

	# Parse # DEPS: header
	deps_line=$(grep -m1 '^# DEPS:' "$script_path" 2>/dev/null || true)
	if [[ -n "$deps_line" ]]; then
		deps="${deps_line#\# DEPS:}"
		deps="$(echo "$deps" | sed 's/,/ /g' | xargs)"
		script_dep_list+=("$deps")
	else
		script_dep_list+=("")
	fi
done

# Scan work scripts from runs-work/ when layer=work
if [[ "$CURRENT_LAYER" == "work" ]]; then
	for script_path in runs-work/*; do
		[[ -f "$script_path" ]] || continue
		name=$(basename "$script_path")
		case "$name" in _*) continue ;; esac

		script_names+=("work/$name")
		script_dirs+=("runs-work")

		deps_line=$(grep -m1 '^# DEPS:' "$script_path" 2>/dev/null || true)
		if [[ -n "$deps_line" ]]; then
			deps="${deps_line#\# DEPS:}"
			deps="$(echo "$deps" | sed 's/,/ /g' | xargs)"
			script_dep_list+=("$deps")
		else
			script_dep_list+=("")
		fi
	done
fi

# Lookup helpers for parallel arrays
get_index() {
	local target="$1"
	local i
	for i in "${!script_names[@]}"; do
		if [[ "${script_names[$i]}" == "$target" ]]; then
			echo "$i"
			return
		fi
	done
	echo "-1"
}

get_deps() {
	local idx
	idx=$(get_index "$1")
	if [[ "$idx" != "-1" ]]; then
		echo "${script_dep_list[$idx]}"
	fi
}

get_dir() {
	local idx
	idx=$(get_index "$1")
	if [[ "$idx" != "-1" ]]; then
		echo "${script_dirs[$idx]}"
	fi
}

# Topological sort using depth-first search
# Track state in space-separated strings (bash 3.2 compatible)
_visit_done=""
_visit_in_progress=""
sorted_order=()

visit() {
	local node="$1"
	# Already done?
	case " $_visit_done " in *" $node "*) return ;; esac
	# Cycle detection
	case " $_visit_in_progress " in
		*" $node "*)
			echo "ERROR: circular dependency involving $node" >&2
			exit 1
			;;
	esac

	_visit_in_progress="$_visit_in_progress $node"

	local deps
	deps=$(get_deps "$node")
	for dep in $deps; do
		visit "$dep"
	done

	_visit_in_progress="${_visit_in_progress% $node}"
	_visit_done="$_visit_done $node"
	sorted_order+=("$node")
}

# Determine which scripts to run
if [[ -n "$filter" ]]; then
	# Resolve filter: try exact match first, then work/ prefix
	if [[ $(get_index "$filter") == "-1" && "$CURRENT_LAYER" == "work" ]]; then
		if [[ $(get_index "work/$filter") != "-1" ]]; then
			filter="work/$filter"
		fi
	fi

	# Bail out if filter matches nothing
	if [[ $(get_index "$filter") == "-1" ]]; then
		echo "ERROR: unknown script '$filter'" >&2
		exit 1
	fi

	# Collect transitive deps for the filtered script
	_needed=""
	collect_deps() {
		local node="$1"
		case " $_needed " in *" $node "*) return ;; esac
		_needed="$_needed $node"
		local deps
		deps=$(get_deps "$node")
		for dep in $deps; do
			collect_deps "$dep"
		done
	}
	collect_deps "$filter"

	# Topologically sort only the needed scripts
	for name in "${script_names[@]}"; do
		case " $_needed " in *" $name "*) visit "$name" ;; esac
	done
else
	for name in "${script_names[@]}"; do
		visit "$name"
	done
fi

# --- Execution ---

# Source shared library so all child scripts have access to helpers
source "$script_dir/runs/_lib.sh"

if [[ "$DRY" == "1" ]]; then
	echo "========== Setting up environment (dry run, layer=$CURRENT_LAYER) =========="
	echo ""
	echo "Execution order: ${sorted_order[*]}"
else
	echo "========== Setting up environment (layer=$CURRENT_LAYER) =========="
fi

for name in "${sorted_order[@]}"; do
	local_dir=$(get_dir "$name")
	# Strip work/ prefix to get the actual filename
	local_file="${name#work/}"

	echo ""
	echo "--- $name ---"
	if [[ "$DRY" == "1" ]]; then
		DRY=1 source "./$local_dir/$local_file"
	else
		source "./$local_dir/$local_file"
	fi
done

# --- Manual steps summary ---
if [[ -s "$MANUAL_STEPS_FILE" ]]; then
	echo ""
	echo "========== Manual Steps =========="
	step_num=1
	while IFS= read -r line; do
		echo "  $step_num. $line"
		step_num=$((step_num + 1))
	done < "$MANUAL_STEPS_FILE"
fi
