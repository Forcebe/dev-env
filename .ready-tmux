#!/usr/bin/env bash

session=$1

pane=$(tmux list-panes -t "=$session:0" -F '#{pane_id}' | head -1)
tmux send-keys -t "$pane" "nvim ." Enter
new_pane=$(tmux split-window -v -t "$pane" -PF '#{pane_id}')
bottom_right=$(tmux split-window -h -t "$new_pane" -PF '#{pane_id}')
tmux send-keys -t "$bottom_right" "claude" Enter
tmux select-pane -t "$pane"
