#!/usr/bin/env bash
set -euo pipefail

STALE_DAYS=14
ACTIVE_HOURS=24

usage() {
	echo "Usage: wt-prune [--dry] [--stale-days N]"
	echo ""
	echo "Remove worktrees under ~/tmrw that are safe to drop. Worktrees in"
	echo "active use are never removed: any file touched in the last"
	echo "${ACTIVE_HOURS}h, or a live tmux session, exempts a worktree (covers an"
	echo "open planning/agent session that hasn't committed yet)."
	echo ""
	echo "  Auto-pruned (clean working tree, no confirmation):"
	echo "    - branch fully merged by content (empty diff vs"
	echo "      origin/develop, origin/main, or origin/master), OR"
	echo "    - branch was pushed and origin/<branch> is gone after"
	echo "      fetch --prune (the classic merged signal)."
	echo ""
	echo "  Confirmed per-branch (stale + unbacked work):"
	echo "    - last commit older than N days (default ${STALE_DAYS}) AND the"
	echo "      branch was never pushed or the tree is dirty. These hold"
	echo "      work with no remote backup, so each is confirmed before"
	echo "      removal — via a terminal prompt when run interactively,"
	echo "      or a macOS dialog (default: Keep) when run in background."
	echo ""
	echo "Options:"
	echo "  --dry          List candidates and fire notification, but do not remove"
	echo "  --stale-days N  Inactivity threshold for the confirm path (default ${STALE_DAYS})"
	exit 1
}

dry=false
while [[ $# -gt 0 ]]; do
	case "$1" in
		--dry) dry=true ;;
		--stale-days)
			shift
			[[ $# -gt 0 && "$1" =~ ^[0-9]+$ ]] || { echo "--stale-days needs a number" >&2; usage; }
			STALE_DAYS="$1" ;;
		-h|--help) usage ;;
		*) echo "Unknown option: $1" >&2; usage ;;
	esac
	shift
done

now=$(date +%s)

shopt -s nullglob
worktree_dirs=("$HOME/tmrw"/*--*/)
shopt -u nullglob

[[ ${#worktree_dirs[@]} -eq 0 ]] && exit 0

# Build parallel arrays: wt_list[i] and main_list[i] are the worktree
# and its main checkout. Dedup mains into unique_mains so we fetch once
# per repo. Bash 3.2 on macOS has no associative arrays, hence the
# parallel-arrays approach.
wt_list=()
main_list=()
unique_mains=()
fetch_ok_mains=()

for wt in "${worktree_dirs[@]}"; do
	wt="${wt%/}"
	main=$(git -C "$wt" worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //')
	[[ -z "$main" ]] && continue
	wt_list+=("$wt")
	main_list+=("$main")
	if [[ ! " ${unique_mains[*]:-} " == *" $main "* ]]; then
		unique_mains+=("$main")
	fi
done

for main in "${unique_mains[@]}"; do
	if git -C "$main" fetch --prune --quiet 2>/dev/null; then
		fetch_ok_mains+=("$main")
	fi
done

kill_session() {
	local dir="$1"
	local session_name
	session_name=$(basename "$dir" | tr ".,: " "____")
	tmux kill-session -t "$session_name" 2>/dev/null || true
}

remove_wt() {
	local wt="$1" main="$2"
	kill_session "$wt"
	git -C "$main" worktree remove --force "$wt" 2>/dev/null
}

# A worktree touched within ACTIVE_HOURS, or with a live tmux session, is
# presumed in use — an open planning/agent session may have made no commits
# and no tracked changes yet, so neither git nor dirtiness reveals it.
# node_modules/.git are pruned from the file scan for speed.
recently_active() {
	local wt="$1" session
	session=$(basename "$wt" | tr ".,: " "____")
	tmux has-session -t "$session" 2>/dev/null && return 0
	[[ -n "$(find "$wt" \( -name node_modules -o -name .git \) -prune -o -type f -mmin "-$((ACTIVE_HOURS * 60))" -print -quit 2>/dev/null)" ]]
}

# Branch introduces nothing not already in a remote base → its content is
# merged, even if the branch itself was never pushed. Three-dot diff so we
# only look at what the branch added since it forked, not how far the base
# moved on. --quiet exits 0 when there's no diff; non-zero (1 = has diff,
# 128 = bad ref) means not-merged-against-this-base, so we try the next.
is_content_merged() {
	local wt="$1" base
	for base in develop main master; do
		git -C "$wt" rev-parse --verify --quiet "origin/$base" >/dev/null 2>&1 || continue
		if git -C "$wt" diff --quiet "origin/${base}...HEAD" 2>/dev/null; then
			return 0
		fi
	done
	return 1
}

# Ask before deleting unbacked work. A TTY gets a terminal prompt; a
# detached background run (the sessionizer fork) gets a macOS dialog that
# defaults to Keep and auto-dismisses, so an unattended pass never deletes.
confirm_delete() {
	local prompt="$1" btn
	if [[ -t 0 ]]; then
		local ans
		read -r -p "$prompt [y/N] " ans </dev/tty || return 1
		[[ "$ans" == "y" || "$ans" == "Y" ]]
	else
		local msg=${prompt//\"/\\\"}
		btn=$(osascript -e "display dialog \"${msg}\" buttons {\"Keep\", \"Delete\"} default button \"Keep\" with title \"Stale worktree\" giving up after 120" 2>/dev/null) || return 1
		[[ "$btn" == *"button returned:Delete"* ]]
	fi
}

removed=()

for i in "${!wt_list[@]}"; do
	wt="${wt_list[$i]}"
	main="${main_list[$i]}"
	# Skip worktrees whose main checkout's fetch failed
	[[ " ${fetch_ok_mains[*]:-} " == *" $main "* ]] || continue

	branch=$(git -C "$wt" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
	[[ -z "$branch" || "$branch" == "HEAD" ]] && continue

	name=$(basename "$wt")

	if recently_active "$wt"; then
		[[ "$dry" == "true" ]] && echo "skip (active <${ACTIVE_HOURS}h): $name"
		continue
	fi

	dirty=false
	[[ -n "$(git -C "$wt" status --porcelain 2>/dev/null)" ]] && dirty=true

	pushed=false
	git -C "$wt" config --get "branch.${branch}.remote" >/dev/null 2>&1 && pushed=true

	remote_gone=false
	if [[ "$pushed" == "true" ]] && ! git -C "$wt" show-ref --verify --quiet "refs/remotes/origin/${branch}"; then
		remote_gone=true
	fi

	# Safe auto-prune: clean tree whose work is already on the remote,
	# either by content or by the pushed-then-deleted signal. The branch
	# ref survives `worktree remove`, so this is recoverable via wt-add.
	if [[ "$dirty" == "false" ]] && { [[ "$remote_gone" == "true" ]] || is_content_merged "$wt"; }; then
		if [[ "$dry" == "true" ]]; then
			echo "would remove (merged): $name"
		else
			remove_wt "$wt" "$main" || continue
		fi
		removed+=("$name")
		continue
	fi

	# Stale + unbacked: old branch that was never pushed, or a dirty tree
	# whose changes exist nowhere else. Confirm each before removing.
	last=$(git -C "$wt" log -1 --format=%ct 2>/dev/null || echo "")
	[[ -z "$last" ]] && continue
	if (( now - last > STALE_DAYS * 86400 )) && { [[ "$pushed" == "false" ]] || [[ "$dirty" == "true" ]]; }; then
		if [[ "$dirty" == "true" ]]; then
			reason="dirty, uncommitted changes only here"
		else
			reason="never pushed, commits only here"
		fi
		if [[ "$dry" == "true" ]]; then
			echo "would prompt (stale, $reason): $name"
			continue
		fi
		if confirm_delete "Delete stale worktree '${name}' (${reason})?"; then
			remove_wt "$wt" "$main" && removed+=("$name")
		fi
		continue
	fi
done

if [[ ${#removed[@]} -gt 0 ]]; then
	if [[ "$dry" == "true" ]]; then
		title="Worktrees would be pruned (dry)"
	else
		title="Worktrees pruned"
	fi
	summary=$(IFS=, ; echo "${removed[*]}")
	# Escape double quotes for AppleScript
	summary_escaped=${summary//\"/\\\"}
	osascript -e "display notification \"${summary_escaped}\" with title \"${title}\"" >/dev/null 2>&1 || true
fi
