#!/usr/bin/env bash
# DEPS: dev-env
source "$(dirname "${BASH_SOURCE[0]:-$0}")/_lib.sh"

log_section "Claude Code"
orphan_npm="/opt/homebrew/lib/node_modules/@anthropic-ai/claude-code"
if [[ -d "$orphan_npm" ]]; then
	log_step "Removing orphaned npm install at $orphan_npm"
	execute rm -rf "$orphan_npm"
fi
if claude --version &>/dev/null; then
	log_skip "Already installed, updating"
	execute claude update
else
	log_step "Installing Claude Code CLI"
	if [[ "$DRY" == "0" ]]; then
		curl -fsSL https://claude.ai/install.sh | bash
	fi
fi

log_section "claude-config"
claude_config_dir="$HOME/personal/claude-config"
clone_or_pull https://github.com/Forcebe/claude-config.git "$claude_config_dir"
log_step "Linking agents/ and skills/ -> ~/.claude/"
execute ln -sfn "$claude_config_dir/agents" "$HOME/.claude/agents"
execute ln -sfn "$claude_config_dir/skills" "$HOME/.claude/skills"

log_manual "Run /reload-plugins in Claude Code to pick up changes"
