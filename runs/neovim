#!/usr/bin/env bash
# DEPS: dev-env, homebrew
source "$(dirname "${BASH_SOURCE[0]:-$0}")/_lib.sh"

NEOVIM_VERSION="0.11.6"

log_section "Neovim source"
clone_or_pull https://github.com/neovim/neovim.git ~/personal/neovim "v$NEOVIM_VERSION"

log_section "Build dependencies"
brew_install ninja cmake gettext curl git

log_section "Build & install"
installed_version=$(nvim --version 2>/dev/null | head -1 | sed 's/NVIM v//')
if [[ "$installed_version" == "$NEOVIM_VERSION" ]]; then
	log_skip "Neovim v$NEOVIM_VERSION already installed"
else
	log_step "Building neovim from source"
	if [[ "$DRY" == "0" ]]; then
		cd ~/personal/neovim
		make CMAKE_BUILD_TYPE=RelWithDebInfo
		sudo make install
		cd - > /dev/null
	fi
fi

log_section "Config dependencies"
brew_install ripgrep fd tree-sitter-cli
