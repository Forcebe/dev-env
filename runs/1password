#!/usr/bin/env bash
# DEPS: dev-env, homebrew
source "$(dirname "${BASH_SOURCE[0]:-$0}")/_lib.sh"

log_section "1Password app"
if [[ -d "/Applications/1Password.app" ]]; then
	log_skip "Already installed"
else
	brew_cask_install 1password
fi

log_section "1Password CLI"
brew_install 1password-cli

if op account list &>/dev/null; then
	log_skip "1Password CLI already authenticated"
else
	log_manual "Log in to 1Password and enable developer integration (Settings > Developer)"
fi
