#!/usr/bin/env bash
# DEPS: homebrew
source "$(dirname "${BASH_SOURCE[0]:-$0}")/_lib.sh"

log_section "1Password app"
if [[ -d "/Applications/1Password.app" ]]; then
	log_skip "Already installed"
else
	brew_cask_install 1password
fi

log_section "1Password CLI"
brew_install 1password-cli
# Refresh PATH lookup so newly-installed `op` is usable in this shell
hash -r

# Gate checks used by the interactive loop.
# `op account list` returns exit 0 with empty output when no account is added,
# so we need to verify at least one account is present (header + >=1 data row = >=2 lines).
op_cli_ok() {
	command -v op &>/dev/null || return 1
	local lines
	lines=$(op account list 2>/dev/null | wc -l)
	[[ "$lines" -ge 2 ]]
}

# ssh -T git@github.com exits 1 on success; detect via stderr substring
# accept-new silently adds github.com to known_hosts on first contact
op_ssh_ok() {
	local out
	out=$(ssh -T -o BatchMode=yes -o StrictHostKeyChecking=accept-new -o ConnectTimeout=5 git@github.com 2>&1 || true)
	[[ "$out" == *"successfully authenticated"* ]]
}

run_sanity_tests() {
	echo ""
	echo "  -> Checking 1Password CLI..."
	if op_cli_ok; then
		echo "     ✓ op account list OK"
	else
		echo "     ✗ op CLI not authenticated"
	fi
	echo "  -> Checking GitHub SSH via 1Password agent..."
	if op_ssh_ok; then
		echo "     ✓ ssh -T git@github.com authenticated"
	else
		echo "     ✗ ssh to github.com not authenticated"
	fi
	echo ""
}

log_section "1Password auth gate"

if [[ "$DRY" == "1" ]]; then
	log_step "Would prompt for 1Password CLI + SSH agent setup (interactive)"
	return 0
fi

if op_cli_ok && op_ssh_ok; then
	log_skip "1Password CLI + SSH agent already authenticated"
elif [[ ! -t 0 ]]; then
	log_skip "Non-interactive shell, skipping 1Password gate"
	log_manual "Set up 1Password CLI + SSH agent, then re-run './run'"
else
	cat <<'EOF'

  1Password setup required. In the 1Password app:
    1. Sign in to your account(s).
    2. Settings > Developer > enable "Integrate with 1Password CLI".
    3. Settings > Developer > enable "Use the SSH agent" (adds IdentityAgent to ~/.ssh/config).
    4. If you have multiple accounts, run: op signin

  Options:
    [Enter]  re-check both gates
    t        run sanity tests (op account list + ssh -T git@github.com)
    s        skip this gate and continue (downstream scripts may fail)
    q        abort the run

EOF
	while true; do
		if op_cli_ok && op_ssh_ok; then
			log_skip "1Password CLI + SSH agent authenticated"
			break
		fi
		read -r -p "  1Password> " answer
		case "$answer" in
			t|T) run_sanity_tests ;;
			s|S)
				log_step "Skipping 1Password gate"
				log_manual "1Password gate was skipped; set up CLI + SSH agent and re-run './run'"
				break
				;;
			q|Q)
				echo "  Aborting run." >&2
				exit 1
				;;
			*) : ;;
		esac
	done
fi
