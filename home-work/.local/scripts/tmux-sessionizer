#!/usr/bin/env bash

# Display aliases for work repos
alias_name() {
	case "$1" in
		tmrw-core-api) echo "CORE" ;;
		tmrw-protocols) echo "ORACLE" ;;
		tmrw-client)    echo "ATLAS" ;;
		*)              echo "$1" ;;
	esac
}

unalias_name() {
	case "$1" in
		CORE)   echo "tmrw-core-api" ;;
		ORACLE) echo "tmrw-protocols" ;;
		ATLAS)  echo "tmrw-client" ;;
		*)      echo "$1" ;;
	esac
}

# Detect sessions with running dev servers (single tmux call, no associative arrays for bash 3 compat)
running_session_list=$(tmux list-panes -a -F '#{session_name}|#{pane_current_command}' 2>/dev/null \
	| grep -E '\|(node|next|npm|npx|tsx|ts-node)$' | cut -d'|' -f1 | sort -u)

# Build active sessions list sorted by most recently used
sessions=""
while IFS='|' read -r path name activity; do
	[[ -z "$name" ]] && continue
	if [[ "$name" == *"--"* ]]; then
		repo_name="${name%%--*}"
		branch="${name#*--}"
		display="$(alias_name "$repo_name")/${branch}"
	else
		display=$(alias_name "$name")
	fi
	if [[ "$path" == "$HOME/tmrw"* ]]; then
		prefix="[WORK]"
	else
		prefix="[PERSONAL]"
	fi
	indicator=" "
	if echo "$running_session_list" | grep -qxF "$name"; then
		indicator="● "
	fi
	sessions+="${activity}|${indicator}${prefix} ${display}"$'\n'
done < <(tmux list-sessions -F "#{session_path}|#{session_name}|#{session_activity}" 2>/dev/null)
sessions=$(echo -n "$sessions" | sort -t'|' -k1 -rn | cut -d'|' -f2)

# Collect active session names to avoid duplicates in directory list
active_session_list=$(tmux list-sessions -F '#{session_name}' 2>/dev/null)

# Build directory list with aliases (skip dirs with active sessions)
directories=""
while IFS= read -r dir; do
	[[ -z "$dir" ]] && continue
	base=$(basename "$dir")
	session_check=$(echo "$base" | tr ".,: " "____")
	echo "$active_session_list" | grep -qxF "$session_check" && continue
	if [[ "$base" == *"--"* ]]; then
		# Worktree directory: tmrw-client--feat-login -> ATLAS/feat-login
		repo_name="${base%%--*}"
		branch="${base#*--}"
		directories+="$(alias_name "$repo_name")/${branch}"$'\n'
	else
		display=$(alias_name "$base")
		if [[ "$display" != "$base" ]]; then
			directories+="$display"$'\n'
		else
			directories+="$dir"$'\n'
		fi
	fi
done < <({ echo ~/tmrw; find ~/personal ~/tmrw -mindepth 1 -maxdepth 1 -type d; } 2>/dev/null)

selected=$(printf '%s\n%s\n' "$sessions" "$directories" | grep -v '^$' | fzf)

if [[ -z "$selected" ]]; then
	exit 0
fi

switch_to() {
	if [[ -z "$TMUX" ]]; then
		tmux attach-session -t "$selected_name"
	else
		tmux switch-client -t "$selected_name"
	fi
}

if [[ "$selected" == *"["*"] "* ]]; then
	# Active session selected — strip running indicator and prefix
	selected="${selected#● }"
	selected="${selected# }"
	display_name="${selected#\[*\] }"
	if [[ "$display_name" == *"/"* ]]; then
		# Worktree format: ATLAS/feat-login -> tmrw-client--feat-login
		alias_part="${display_name%%/*}"
		branch_part="${display_name#*/}"
		selected_name="$(unalias_name "$alias_part")--${branch_part}"
	else
		selected_name=$(unalias_name "$display_name")
	fi
	switch_to
else
	# Directory or alias selected
	if [[ "$selected" == *"/"* && "$selected" != "$HOME"* ]]; then
		# Worktree alias format: ATLAS/feat-login
		alias_part="${selected%%/*}"
		branch_part="${selected#*/}"
		real_repo=$(unalias_name "$alias_part")
		selected="$HOME/tmrw/${real_repo}--${branch_part}"
		selected_name="${real_repo}--${branch_part}"
	else
		# Regular alias or full path
		real_name=$(unalias_name "$selected")
		if [[ "$real_name" != "$selected" ]]; then
			selected="$HOME/tmrw/$real_name"
		fi
		selected_name=$(basename "$selected" | tr ".,: " "____")
	fi

	if tmux has-session -t="$selected_name" 2> /dev/null; then
		switch_to
	else
		tmux new-session -ds "$selected_name" -c "$selected"
		tmux-init "$selected_name" "$selected"
		switch_to
	fi
fi
